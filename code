    p.hp         = 80; 
    p.maxHp      = 80; 
    p.attack     = 8; 
    p.gold        = 10; 
    p.currentRoom = 0; 
    p.itemCount   = 1; 
 
    // Starting item 
    strcpy(p.inventory[0].name, "Small Potion"); 
    p.inventory[0].healAmount  = 15; 
