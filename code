// ─── Constants ─────────────────────────────────────────────── 
const int MAX_INVENTORY = 6; 
const int NUM_ROOMS     = 5; 
const int NUM_ENEMIES   = 4; 
const int NAME_LEN      = 30; 
 
// ─── Structs ───────────────────────────────────────────────── 
struct Item { 
    char name[NAME_LEN]; 
    int  healAmount;   // 0 = weapon/armour, >0 = potion 
    int  attackBonus; 
}; 
 
struct Enemy { 
    char name[NAME_LEN]; 
    int  hp; 
    int  maxHp; 
    int  attack; 
    bool alive; 
}; 
 
struct Player { 
    char name[NAME_LEN]; 
    int  hp; 
    int  maxHp; 
    int  attack; 
    int  gold; 
    int  currentRoom; 
    Item inventory[MAX_INVENTORY]; 
    int  itemCount; 
}; 
 
struct Room { 
    char description[120]; 
    bool hasEnemy; 
    bool hasItem; 
    bool visited; 
    int  enemyIndex;   // index into global enemy array 
    Item loot; 
}; 
 
// ─── Global Game State ─────────────────────────────────────── 
Enemy enemies[NUM_ENEMIES] = { 
    {"Goblin",        20, 20, 4,  true}, 
    {"Skeleton",      30, 30, 6,  true}, 
    {"Dark Knight",   50, 50, 10, true}, 
    {"Shadow Wraith", 40, 40, 8,  true} 
}; 
 
Room rooms[NUM_ROOMS]; 
 
