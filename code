// ─── cctype Helpers ────────────────────────────────────────── 
 
// Capitalize first letter of each word using cctype 
string capitalize(const string &s) { 
    string result = s; 
    bool newWord = true; 
    for (size_t i = 0; i < result.size(); ++i) { 
        if (isspace((unsigned char)result[i])) { 
            newWord = true; 
        } else if (newWord) { 
            result[i] = (char)toupper((unsigned char)result[i]); 
            newWord = false; 
        } else { 
            result[i] = (char)tolower((unsigned char)result[i]); 
        } 
    } 
    return result; 
} 
 
// Validate that a name contains only letters and spaces (cctype: isalpha, isspace) 
bool isValidName(const char *s) { 
    if (strlen(s) == 0) return false; 
    for (int i = 0; s[i] != '\0'; ++i) { 
        if (!isalpha((unsigned char)s[i]) && !isspace((unsigned char)s[i])) 
            return false; 
    } 
    return true; 
} 
 
// ─── Initialisation ────────────────────────────────────────── 
 
